{
  "name": "fulfillpay",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "contracts:clean": "corepack pnpm --filter @fulfillpay/contracts clean",
    "contracts:compile": "corepack pnpm --filter @fulfillpay/contracts compile",
    "contracts:deploy:local": "corepack pnpm --filter @fulfillpay/contracts deploy:local",
    "contracts:deploy:testnet": "corepack pnpm --filter @fulfillpay/contracts deploy:testnet",
    "contracts:e2e:mock:testnet": "corepack pnpm --filter @fulfillpay/contracts e2e:mock:testnet",
    "contracts:e2e:mock:boundaries:testnet": "corepack pnpm --filter @fulfillpay/contracts e2e:mock:boundaries:testnet",
    "contracts:node": "corepack pnpm --filter @fulfillpay/contracts node",
    "contracts:test": "corepack pnpm --filter @fulfillpay/contracts test",
    "contracts:typecheck": "corepack pnpm --filter @fulfillpay/contracts typecheck",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "corepack pnpm --filter @fulfillpay/contracts test:e2e",
    "test:red-team": "corepack pnpm --filter @fulfillpay/contracts test:red-team",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  }
}
