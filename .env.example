# FulfillPay environment example
# Copy values into your local `.env` and replace placeholders before running real-network tests.

# 0G Galileo testnet
ZERO_G_EVM_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_STORAGE_PRIVATE_KEY=0xYOUR_0G_TESTNET_WALLET_PRIVATE_KEY

# FulfillPay settlement network
CHAIN_ID=16602
SETTLEMENT_CONTRACT=0xYOUR_FULFILLPAY_SETTLEMENT_CONTRACT

# Optional role wallets for end-to-end tests
BUYER_PRIVATE_KEY=0xYOUR_BUYER_PRIVATE_KEY
SELLER_PRIVATE_KEY=0xYOUR_SELLER_PRIVATE_KEY
VERIFIER_PRIVATE_KEY=0xYOUR_VERIFIER_PRIVATE_KEY

# Optional local verifier service
VERIFIER_SERVICE_URL=http://127.0.0.1:3000
