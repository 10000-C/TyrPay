    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tyrpay/sdk-core": "workspace:*",
    "@tyrpay/storage-adapter": "workspace:*",
    "@tyrpay/zktls-adapter": "workspace:*",
    "dotenv": "^16.5.0",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.4"
  }
}
