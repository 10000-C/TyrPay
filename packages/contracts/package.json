{
  "name": "@fulfillpay/contracts",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "hardhat compile",
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network testnet",
    "e2e:mock:testnet": "hardhat run scripts/e2e-mock-testnet.ts --network testnet",
    "e2e:mock:boundaries:testnet": "hardhat run scripts/e2e-mock-boundaries-testnet.ts --network testnet",
    "node": "hardhat node",
    "smoke:local": "hardhat run scripts/smoke-local.ts --network localhost",
    "test": "hardhat test",
    "test:e2e": "hardhat test ../../test/e2e/e2e-happy-path.test.ts ../../test/e2e/e2e-model-usage.test.ts ../../test/e2e/e2e-replay-protection.test.ts ../../test/e2e/e2e-invalid-verifier.test.ts ../../test/e2e/e2e-boundary-cases.test.ts ../../test/e2e/e2e-timeout-refund.test.ts ../../test/e2e/e2e-invalid-signature.test.ts ../../test/e2e/e2e-eip712-rejection.test.ts ../../test/e2e/e2e-commitment-validation.test.ts ../../test/e2e/e2e-multi-task.test.ts",
    "test:red-team": "hardhat test ../../test/e2e/e2e-red-team-boundary.test.ts",
    "test:coverage": "hardhat coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@fulfillpay/buyer-sdk": "workspace:*",
    "@fulfillpay/sdk-core": "workspace:*",
    "@fulfillpay/seller-sdk": "workspace:*",
    "@fulfillpay/storage-adapter": "workspace:*",
    "@fulfillpay/verifier-service": "workspace:*",
    "@fulfillpay/zktls-adapter": "workspace:*",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "chai": "^4.5.0",
    "dotenv": "^16.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.26.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
