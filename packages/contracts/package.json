    "@tyrpay/zktls-adapter": "workspace:*",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "chai": "^4.5.0",
