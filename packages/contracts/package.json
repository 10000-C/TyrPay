    "deploy:testnet": "hardhat run scripts/deploy.ts --network testnet",
    "e2e:mock:testnet": "hardhat run scripts/e2e-mock-testnet.ts --network testnet",
    "e2e:reclaim:testnet": "hardhat run scripts/e2e-reclaim-testnet.ts --network testnet",
