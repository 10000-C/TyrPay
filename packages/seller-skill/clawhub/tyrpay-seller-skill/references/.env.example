# =============================================================================
# @tyrpay/seller-skill  —  Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values before running seller-skill.
#
# seller-skill itself receives all config through constructor parameters;
# the variables below are needed to build those parameters (signer, adapters,
# contract address, etc.) at application startup.
# =============================================================================

# ── Settlement Chain & Wallet (required) ─────────────────────────────────────

# EVM RPC endpoint for the 0G settlement chain.
# Used by ethers provider, 0G storage adapter, and on-chain interactions.
ZERO_G_EVM_RPC=https://evmrpc.0g.ai

# Seller wallet private key (hex, with or without 0x prefix).
# Used to create the ethers Signer that signs all on-chain transactions.
SELLER_PRIVATE_KEY=

# Settlement chain ID. Must match the network behind ZERO_G_EVM_RPC.
# 16661 = 0G mainnet, 16602 = 0G Galileo testnet.
CHAIN_ID=16661

# Deployed TyrPaySettlement contract address on the settlement chain.
SETTLEMENT_CONTRACT=0x6D548b2eD427ABeb1564e0A65C5FC8d5A8394ad9

# ── 0G Storage Adapter (production required) ─────────────────────────────────
# Required when using ZeroGStorageAdapter.
# Omit this section when using MemoryStorageAdapter (testing only).

# 0G storage indexer endpoint for reading stored objects.
ZERO_G_INDEXER_RPC=https://indexer-storage-turbo.0g.ai

# Private key used to upload proof bundles and receipts to 0G storage.
# Can differ from SELLER_PRIVATE_KEY.
ZERO_G_STORAGE_PRIVATE_KEY=

# ── Reclaim zkTLS Adapter (production required) ──────────────────────────────
# Required when using ReclaimZkTlsAdapter.
# Omit this section when using MockZkTlsAdapter (testing only).

# Reclaim protocol application ID.
RECLAIM_APP_ID=

# Reclaim protocol application secret.
RECLAIM_APP_SECRET=

# ── Upstream Model API (runtime required) ────────────────────────────────────
# The model API key / URL are typically passed at call time via providerOptions,
# but many integrations load them from the environment.

# API key for the upstream LLM provider (e.g. OpenAI, DeepSeek).
MODEL_API_KEY=

# Base URL of the upstream LLM provider.
MODEL_BASE_URL=https://api.openai.com

# Model name to use for completions.
MODEL_NAME=gpt-4o-mini

# ── Verifier (optional) ──────────────────────────────────────────────────────

# Verifier signer address registered on-chain.
# Passed as verifierSignerAddress to SellerSkillConfig.
VERIFIER_SIGNER_ADDRESS=0x2833BfA9a65D77dC61a0A7d2D74d84E73ca60Ab0

# Deployed verifier contract address (used in some setups).
VERIFIER_CONTRACT=0x20Fd439a0BB7F250d7a097Bffe465e8f7D1a97dc

# Local verifier service URL 
VERIFIER_SERVICE_URL=

# ── Debug / Testing (optional) ───────────────────────────────────────────────

# Set to "1" to enable end-to-end timing logs in SellerAgent.provenFetch().
tyrpay_E2E_TIMING=
