  },
  "dependencies": {
    "@fulfillpay/sdk-core": "workspace:*",
    "@fulfillpay/storage-adapter": "workspace:*",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30"
  }
}
